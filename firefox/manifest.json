{
  "manifest_version": 2,
  "name": "AutoPrompt for Copilot",
  "version": "1.2.0",
  "description": "Automate batch prompts on Microsoft Copilot, M365 Copilot, GitHub Copilot & Teams Copilot. Run prompts hands-free with pause, resume & progress.",
  "permissions": [
    "storage",
    "tabs",
    "https://copilot.microsoft.com/*",
    "https://m365.cloud.microsoft/chat*",
    "https://m365.cloud.microsoft/chat/*",
    "https://github.com/copilot*",
    "https://github.com/copilot/*",
    "https://teams.microsoft.com/*",
    "https://outlook.office.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://copilot.microsoft.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://m365.cloud.microsoft/chat", "https://m365.cloud.microsoft/chat/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/copilot", "https://github.com/copilot/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://teams.microsoft.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://outlook.office.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background/background.js"]
  },
  "web_accessible_resources": [
    "data/sample-prompts.json",
    "landing/landing.html",
    "landing/landing.css"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "autoprompt-for-copilot@example.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
