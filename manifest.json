{
  "manifest_version": 3,
  "name": "AutoPrompt for Copilot",
  "version": "1.2.0",
  "description": "Automate batch prompts on Microsoft Copilot, M365 Copilot & GitHub Copilot. Run prompts hands-free with pause, resume & progress.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://copilot.microsoft.com/*",
    "https://m365.cloud.microsoft/chat*",
    "https://m365.cloud.microsoft/chat/*",
    "https://github.com/copilot*",
    "https://github.com/copilot/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://copilot.microsoft.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://m365.cloud.microsoft/chat", "https://m365.cloud.microsoft/chat/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/copilot", "https://github.com/copilot/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/sample-prompts.json", "landing/landing.html", "landing/landing.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
