{
  "manifest_version": 3,
  "name": "AutoPrompt for Copilot",
  "version": "1.0.0",
  "description": "Automate batch prompts on Microsoft Copilot — run sample or custom prompts, one after another.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["https://copilot.microsoft.com/*"],
  "content_scripts": [
    {
      "matches": ["https://copilot.microsoft.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/sample-prompts.json", "landing/landing.html", "landing/landing.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
